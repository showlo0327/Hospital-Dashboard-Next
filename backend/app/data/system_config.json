{
  "_schema": "2.0",
  "_description": "Centralized system configuration. Future Settings page reads/writes this file through the Backend API.",

  "ping": {
    "history_size": 20,
    "latency_window": 5,
    "offline_threshold": 5,
    "recovery_threshold": 3,
    "worker_count": 50,
    "scan_interval_seconds": 30,
    "ping_timeout_seconds": 2,
    "ping_ttl": 64,
    "enabled": true
  },

  "csv": {
    "max_file_size_mb": 10,
    "allowed_encodings": ["utf-8", "utf-8-sig", "gbk", "gb2312"],
    "default_encoding": "utf-8"
  },

  "snmp": {
    "enabled": false,
    "default_port": 161,
    "default_community": "public",
    "timeout_seconds": 3,
    "retries": 2,
    "scan_interval_seconds": 300
  },

  "ui": {
    "auto_refresh_enabled": false,
    "auto_refresh_interval_seconds": 60,
    "default_view": "list"
  }
}
